# ── ccbot 环境变量配置 ──
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ── Claude API ──
ANTHROPIC_API_KEY=sk-ant-xxx

# ── 飞书机器人 ──
NANOBOT_FEISHU__APP_ID=cli_xxx
NANOBOT_FEISHU__APP_SECRET=
NANOBOT_FEISHU__ENCRYPT_KEY=
NANOBOT_FEISHU__VERIFICATION_TOKEN=

# ── 飞书权限 ──
# NANOBOT_FEISHU__REQUIRE_MENTION=false
# NANOBOT_FEISHU__DM_POLICY=open
# NANOBOT_FEISHU__REACT_EMOJI=THUMBSUP

# ── Agent 配置 ──
# NANOBOT_AGENT__MODEL=claude-sonnet-4-6
# NANOBOT_AGENT__MAX_TURNS=10
# NANOBOT_AGENT__MAX_WORKERS=4
# NANOBOT_AGENT__IDLE_TIMEOUT=28800
# NANOBOT_AGENT__HEARTBEAT_ENABLED=true
# NANOBOT_AGENT__HEARTBEAT_INTERVAL=1800

# ── A2A 服务器（可选）──
# NANOBOT_A2A__ENABLED=false
# NANOBOT_A2A__HOST=0.0.0.0
# NANOBOT_A2A__PORT=8765
