# ── ccbot 环境变量配置 ──
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ── Claude API / 兼容 API ──
# 原生 Anthropic API:
#   ANTHROPIC_API_KEY=sk-ant-xxx
# 兼容 API（如 Kimi）:
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=

# Claude Code 实验性功能
# CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# ── 飞书机器人 ──
CCBOT_FEISHU__APP_ID=
CCBOT_FEISHU__APP_SECRET=
# CCBOT_FEISHU__ENCRYPT_KEY=
# CCBOT_FEISHU__VERIFICATION_TOKEN=

# ── 飞书权限与交互 ──
# CCBOT_FEISHU__REQUIRE_MENTION=false
# CCBOT_FEISHU__DM_POLICY=open
# CCBOT_FEISHU__GROUP_POLICY=open
# CCBOT_FEISHU__REACT_EMOJI=THINKING
# CCBOT_FEISHU__PROGRESS_MODE=milestone

# ── Agent 配置 ──
# CCBOT_AGENT__MODEL=claude-sonnet-4-6
# CCBOT_AGENT__MAX_TURNS=10
# CCBOT_AGENT__MAX_WORKERS=4
# CCBOT_AGENT__IDLE_TIMEOUT=28800
# CCBOT_AGENT__HEARTBEAT_ENABLED=true
# CCBOT_AGENT__HEARTBEAT_INTERVAL=1800

# ── A2A 服务器（可选）──
# CCBOT_A2A__ENABLED=false
# CCBOT_A2A__HOST=0.0.0.0
# CCBOT_A2A__PORT=8765
