{
  "// 说明": "nanobot 完整配置示例",
  "// 优先级": "环境变量 > JSON 文件 > 默认值",

  "feishu": {
    "// 认证配置": "必填项",
    "app_id": "cli_your_app_id",
    "app_secret": "your_app_secret",
    "encrypt_key": "",
    "verification_token": "",

    "// 权限配置": "控制谁可以使用机器人",
    "allow_from": ["*"],
    "dm_policy": "open",
    "group_policy": "open",
    "require_mention": false,

    "// 交互配置": "用户体验相关",
    "react_emoji": "THUMBSUP",
    "progress_mode": "milestone"
  },

  "agent": {
    "// 基础配置": "核心参数",
    "model": "claude-sonnet-4-6",
    "workspace": "~/.nanobot/workspace",
    "max_turns": 10,

    "// SDK 配置": "工具和 MCP 服务器",
    "allowed_tools": [],
    "mcp_servers": {},

    "// Heartbeat 配置": "定时任务",
    "heartbeat_enabled": true,
    "heartbeat_interval": 1800,
    "heartbeat_notify_chat_id": "",

    "// Worker 模式": "供 nanobot worker 命令使用",
    "system_prompt": "",
    "cwd": ""
  },

  "a2a": {
    "// A2A 协议": "Agent-to-Agent 通信",
    "enabled": false,
    "host": "0.0.0.0",
    "port": 8765,
    "name": "nanobot",
    "description": "Claude Agent SDK powered assistant"
  }
}
